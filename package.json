{
  "name": "semaphore-cli",
  "version": "1.0.0",
  "description": "CLI for the USB-HID traffic-light semaphore device (VID 0x1209, PID 0x0001).",
  "bin": {
    "semaphore": "cli.js"
  },
  "files": [
    "cli.js",
    "scripts"
  ],
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "hid",
    "usb",
    "led",
    "traffic-light",
    "semaphore",
    "claude-code",
    "hooks"
  ],
  "author": "Artem Makarov",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "node-hid": "3.3.0"
  },
  "allowScripts": {
    "node-hid@3.3.0": true
  }
}
